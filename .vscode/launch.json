{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(gdb) Launch ZMenu",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/zmenun",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                { "name": "WAYLAND_DISPLAY", "value": "wayland-0" },
                { "name": "GDK_BACKEND", "value": "wayland" }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "gcc build",
            "miDebuggerPath": "/usr/bin/gdb"
        }
    ],
    "setupCommands": [
    {
        "description": "Enable pretty-printing for gdb",
        "text": "-enable-pretty-printing",
        "ignoreFailures": true
    },
    {
        "description": "Ignorar SIGPIPE (común en Wayland sockets)",
        "text": "handle SIGPIPE nostop noprint pass",
        "ignoreFailures": true
    }
]
    
}